---
const { caption, cssClass, index, site, src, total } = Astro.props

// A random string with the syntax '[a-z][0-9]{3}-index-total'
const key = Math.random().toString(36).slice(2, 6) + '-' + index + '/' + total
---

<a-work class={cssClass}>
  <div class="a__inner">
    <div>
      <video
        data-src={src}
        class="a__video js-video"
        loop
        muted
        playsinline
        width="1082"
        height="636"
      >
      </video>

      <div class="a__caption">
        <div class="a__caption__text">
          {caption}
        </div><!-- .a__caption__text -->

        <div class="a__caption__key">
          #{key}
        </div><!-- .a__caption__key -->
      </div><!-- .a__caption -->
    </div>
  </div><!-- .a__inner -->
</a-work>

<script>
  class AWork extends HTMLElement {
    static observedAttributes = ['progress']

    video: HTMLVideoElement

    isPlaying: boolean

    /**
     * Init
     */
    connectedCallback() {
      // Elements
      this.video = this.querySelector('.js-video')

      // Properties
      this.isPlaying = false
    }

    /**
     * Attribute changed
     */
    attributeChangedCallback(name, oldValue, newValue) {
      if (name === 'progress') {
        this.style.setProperty('--progress', newValue)

        if (newValue === '1' || newValue === '-1') {
          if (this.isPlaying) {
            this.outView()
          }
        } else {
          if (!this.isPlaying) {
            this.inView()
          }
        }
      }
    }

    /**
     * Gets in view
     */
    inView() {
      this.video.play()
      this.isPlaying = true

      this.classList.add('is-inview')
    }

    /**
     * Gets out view
     */
    outView() {
      this.video.pause()
      this.isPlaying = false

      this.classList.remove('is-inview')
    }

  }

  customElements.define('a-work', AWork)
</script>

<style lang="scss">
  a-work {
    position: relative;
    top: 0;
    left: 0;

    display: block;
    margin: 0;
    padding: 0;

    background: color(secondary);
    content-visibility: hidden;

    border-radius: 999px;
    overflow: hidden;

    transform-style: preserve-3d;

    will-change: transform;

    .a__inner > div {
      display: block;
    }

    .a__inner {
      display: block;
      margin: 0;
      padding: 0;
    }

    .a__video {
      display: block;

      width: 18vw;
      height: 50vh;
      object-fit: cover;
      object-position: center center;

      @include mq(tablet) {
        width: 28vw;
        height: 50vh;
      }

      @include mq(phone) {
        width: 42vw;
        height: 55vh;
      }
    }

    .a__caption {
      @include flex(row, center, space-between);

      padding: 0.5rem 0.5rem;

      color: color(primary);
      font: 700 11px / 1 font-family(fraktion);
      letter-spacing: 0.15em;
      text-align: right;
      text-transform: uppercase;

      @include mq(phone) {
        display: none;
      }
    }

    &.is-inview {
      content-visibility: visible;
    }
  }
</style>
