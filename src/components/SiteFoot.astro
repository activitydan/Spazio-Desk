<style lang="scss">
  .site-foot {
    @include flex(row, center, center);

    position: relative;
    z-index: 3;

    padding: 1.5rem;

    @include mq(phone) {
      padding: 1rem;
    }

    &__logo {
      svg {
        display: block;
        width: 5rem;
        height: 5rem;
        color: color(secondary);

        @include mq(phone) {
          width: 3rem;
          height: 3rem;
        }
      }
    }
  }
</style>
