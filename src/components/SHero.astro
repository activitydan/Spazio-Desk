---
import AWaves from './AWaves.astro'
---

<div class="s-hero" data-intersect>
  <AWaves class="s__waves" />

  <div class="s__content js-content">
    <div class="s__marquee">
      <div class="s__marquee__track">
        <span class="s__marquee__item">SPAZIO DESK</span>
        <span class="s__marquee__item">SPAZIO DESK</span>
        <span class="s__marquee__item">SPAZIO DESK</span>
        <span class="s__marquee__item">SPAZIO DESK</span>
      </div>
    </div>
  </div>

  <div class="s__border js-border"></div>
</div><!-- .s-hero -->

<script>
  import Emitter from '../utils/Emitter'

  import { gsap } from 'gsap'
  import { DrawSVGPlugin } from 'gsap/DrawSVGPlugin'
  gsap.registerPlugin(DrawSVGPlugin)

  class Section {
    el: HTMLElement

    constructor() {
      this.el = document.querySelector('.s-hero')

      if (document.readyState === 'complete') {
        this.init()
      } else {
        Emitter.once('siteLoaded', this.init, this)
      }
    }

    init() {
      document.addEventListener('intro', this.intro.bind(this), { once: true })
    }

    intro() {
      const waves = this.el.querySelector('a-waves')
      const lines = waves.querySelectorAll('.js-line')
      const content = this.el.querySelector('.js-content')
      const border = this.el.querySelector('.js-border')
      const separators = content.querySelectorAll('.js-separator')

      const tl = gsap.timeline()

      tl.fromTo(
        lines,
        { drawSVG: '100% 100%' },
        {
          drawSVG: '0% 100%',
          duration: 3,
          ease: 'expo.out',
          stagger: {
            amount: 0.5,
            from: 'edges',
            ease: 'power3.inOut',
          },
        },
        0.5
      )

      tl.call(() => {
        waves.dispatchEvent(new CustomEvent('introend'))
      }, null, '-=1')

      tl.set(this.el, { opacity: 1 }, 0)

      tl.to(
        border,
        { scaleY: 0.025, y: -content.clientHeight, duration: 1, ease: 'expo.inOut' },
        0
      )

      tl.from(
        waves,
        { y: '100%', duration: 1.35, ease: 'expo.out' },
        0
      )

      tl.fromTo(
        content,
        { clipPath: 'polygon(0 0, 100% 0, 100% 0, 0 0)' },
        { clipPath: 'polygon(0 0, 100% 0, 100% 100%, 0 100%)', duration: 1, ease: 'expo.inOut' },
        1
      )

      tl.to(
        border,
        { scaleY: 1, y: 0, duration: 1, ease: 'expo.inOut' },
        1
      )

      tl.from(
        separators,
        {
          y: (index) => (index % 2 === 0 ? '-100%' : '100%'),
          duration: 1.5,
          ease: 'expo.inOut',
        },
        0.75
      )
    }
  }

  new Section()
</script>

<style lang="scss">
  .s-hero {
    @include flex(column, stretch, stretch);

    position: relative;
    z-index: 4;

    min-height: calc(100svh - 7rem);

    opacity: 0;
    overflow: hidden;

    @include mq(phone) {
      min-height: calc(100svh - 4.5rem);
    }

    .s__waves {
      width: 100%;
      height: 100%;

      flex-grow: 1;
      flex-shrink: 1;
    }

    .s__border {
      position: absolute;
      top: 100%;
      left: 0;

      width: 100%;
      height: 40 * 1rem;

      background: color(secondary);
      transform-origin: 50% 0;

      @include mq(phone) {
        height: 40 * 0.5rem;
      }
    }

    .s__content {
      position: relative;

      overflow: hidden;
      transform-origin: 50% 100%;

    }

    .s__marquee {
      overflow: hidden;
      width: 100%;

      &__track {
        display: flex;
        width: max-content;

        will-change: transform;
        animation: s-hero-marquee 35s linear infinite;
      }

      &__item {
        font: 700 clamp(2.55rem, 11.05vw, 15.73rem) / 1 'Helvetica Neue', Helvetica, Arial, sans-serif;
        text-transform: uppercase;
        letter-spacing: -4px;
        white-space: nowrap;
        color: color(secondary);

        padding: 1.5rem 1.5em 1.5rem 0;
        flex-shrink: 0;

        @include mq(tablet) {
          padding-top: 1rem;
          padding-bottom: 1rem;
        }
      }
    }

    @keyframes s-hero-marquee {
      from { transform: translateX(-25%); }
      to   { transform: translateX(0); }
    }
  }
</style>
