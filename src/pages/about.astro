---
import SiteHead from '../components/SiteHead.astro'
import SiteFoot from '../components/SiteFoot.astro'
import SiteCursor from '../components/SiteCursor.astro'
import '../styles/global.scss'

const base = import.meta.env.BASE_URL
---

<html lang="it" class="is-scroll-blocked theme-contrasted page-about">
  <head>
    <meta charset="utf-8" />
    <script is:inline>
      try {
        var sdTheme = localStorage.getItem('sd-theme')
        if (sdTheme === 'default') {
          document.documentElement.classList.remove('theme-contrasted')
        } else if (sdTheme === 'contrasted') {
          document.documentElement.classList.add('theme-contrasted')
        }
      } catch (e) {}
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Alberto Lauria</title>
    <meta name="description" content="Spazio Desk è uno studio collettivo creativo con base in Sicilia. Branding strategico, identità visiva, direzione creativa e progettazione di sistemi di comunicazione." />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://spaziodesk.com/about" />
    <meta property="og:locale" content="it_IT" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Alberto Lauria" />
    <meta property="og:description" content="Spazio Desk è uno studio collettivo creativo con base in Sicilia. Branding strategico, identità visiva, direzione creativa e progettazione di sistemi di comunicazione." />
    <meta property="og:url" content="https://spaziodesk.com/about" />
    <meta property="og:site_name" content="Spazio Desk" />
    <meta property="og:image" content="https://spaziodesk.com/images/og-image.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://spaziodesk.com/images/og-image.png" />

    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Organization',
      name: 'Spazio Desk',
      url: 'https://spaziodesk.com',
      member: [
        {
          '@type': 'Person',
          name: 'Alberto Lauria',
          url: 'https://albertolauria.com',
          sameAs: ['https://albertolauria.com'],
        },
      ],
    })} />

    <link rel="icon" type="image/png" href={`${base}icons/favicon-16x16.png`} sizes="16x16" />
    <link rel="icon" type="image/png" href={`${base}icons/favicon-32x32.png`} sizes="32x32" />
    <link rel="shortcut icon" href={`${base}icons/favicon.ico`} />

    <link
      rel="preload"
      href={`${base}fonts/PPFraktionMono-Regular.woff2`}
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      href={`${base}fonts/PPFraktionMono-Bold.woff2`}
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />

    <link rel="stylesheet" href={`${base}fonts/fraktion-mono.css`} />
  </head>

  <body>
    <div class="site-wrapper js-site-wrapper" style="opacity: 0;">
      <SiteHead menuItems={[
        { id: 'desk', text: 'Desk', href: '/' },
        { id: 'contact', text: 'Contact', href: '/contact' },
      ]} />

      <main class="s-about" data-intersect>
        <div class="about-text">
          <p>Spazio Desk è uno studio collettivo creativo con base in Sicilia, specializzato nella creazione di identità visiva, direzione creativa e progettazione di sistemi di comunicazione. Lo studio affianca aziende, piccole e medie imprese, startup e progetti indipendenti nella costruzione di identità capaci di esprimere con chiarezza il proprio valore, traducendo strategie e visioni in sistemi coerenti, riconoscibili e duraturi.</p>
          <p>Ogni progetto nasce da un processo che integra l'analisi e la ricerca, con l'obiettivo di sviluppare soluzioni che non rispondano soltanto a esigenze funzionali, ma che contribuiscano a costruire una cultura di marca solida e distintiva.</p>
          <p>L'approccio di Spazio Desk affronta ogni incarico con attenzione al contesto, alle persone e agli obiettivi dell'organizzazione. Più che produrre elementi di comunicazione, lo studio progetta strumenti capaci di dare ordine alla complessità e valore alle relazioni tra brand, persone e territorio.</p>
        </div>

        <div class="members-section">
          <p class="members-title">Members of the Team</p>
          <div class="members-list">
            <a href="https://albertolauria.com" target="_blank" rel="noreferrer" class="members-name members-name--link">Alberto Lauria</a>
            <a href={`${base}about/dan`} class="members-name members-name--link">Dan</a>
            <a href={`${base}about/lorenzo`} class="members-name members-name--link">Lorenzo Bernardini</a>
          </div>
        </div>
      </main>

      <SiteFoot />
    </div><!-- .site-wrapper -->

    <div
      class="site-intro js-intro"
      style="opacity: 1; position: fixed; top: 0; left: 0; z-index: 50; width: 100%; height: 100%;"
    >
      <div class="sb-logo js-logo">
        <svg class="js-logo-svg" viewBox="0 0 1024 1024" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path fill="currentColor" d="M577.800293,507.433289 C574.412048,498.392303 567.903687,494.303131 558.894226,493.950012 C553.899841,493.754242 548.878052,493.884857 544.078430,492.209473 C535.373169,489.170654 530.282959,482.502747 530.716736,473.324463 C531.451416,457.778717 519.952942,449.576141 507.640564,450.063507 C491.333466,450.708984 474.981110,450.180725 458.648499,450.236664 C455.109772,450.248779 451.635468,449.789093 448.297699,448.819305 C439.076263,446.140137 433.044098,438.842590 433.835754,429.124146 C435.056915,414.132874 423.228851,405.976501 410.457428,406.286469 C393.468048,406.698792 376.460602,406.452362 359.461639,406.357544 C345.222321,406.278107 336.817352,397.737976 336.766144,383.545471 C336.720520,370.913605 329.019165,363.101105 316.182312,363.007111 C299.183685,362.882599 282.183594,362.952637 265.184113,362.962463 C261.325806,362.964691 257.532532,362.626862 253.869873,361.316620 C245.455002,358.306274 240.662292,351.643066 240.656067,342.729553 C240.634918,312.397156 241.027130,282.057861 240.473114,251.735611 C240.241302,239.048141 250.780273,230.883789 260.727570,230.830505 C295.891968,230.642105 331.059570,230.577789 366.222565,230.873138 C378.124573,230.973099 386.764709,240.123077 386.205444,251.887314 C385.529633,266.104950 395.539124,274.704987 409.326294,274.649017 C426.492157,274.579376 443.658600,274.609192 460.824646,274.649567 C475.037781,274.683014 483.102631,282.770630 483.197083,296.980469 C483.283142,309.930115 490.944733,317.795258 503.973755,317.904480 C521.305420,318.049713 538.639099,317.981354 555.971863,317.951172 C560.545715,317.943207 564.950500,318.561493 568.996216,320.811584 C575.608337,324.489075 579.384644,329.818207 579.389404,337.700195 C579.399353,354.288300 586.976624,361.688660 603.633667,361.691254 C620.799805,361.693939 637.966492,361.607880 655.131897,361.717224 C667.439392,361.795593 676.830383,370.417053 676.154236,382.249359 C675.331421,396.649017 684.753113,405.499268 699.770447,405.58