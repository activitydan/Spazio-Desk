---
const base = import.meta.env.BASE_URL
---

<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Lorenzo Bernardini — Spazio Desk</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/png" href={`${base}icons/favicon-16x16.png`} sizes="16x16" />
    <link rel="icon" type="image/png" href={`${base}icons/favicon-32x32.png`} sizes="32x32" />
    <link rel="shortcut icon" href={`${base}icons/favicon.ico`} />
  </head>
  <body>
    <div class="wip">
      <span>Work in Progress</span>
    </div>
  </body>

  <style>
    html, body {
      margin: 0;
      padding: 0;
      width: 100%;
      height: 100%;
      background: #ffffff;
    }
    .wip {
      height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
    }
    .wip span {
      font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
      font-weight: bold;
      text-transform: uppercase;
      letter-spacing: -4px;
      font-size: 3rem;
      color: #000000;
    }
  </style>
</html>
